# Скопируйте этот файл в .env и подставьте свои значения:
#   cp .env.example .env

# --- Домен / DuckDNS ---
# Поддомен DuckDNS (без .duckdns.org) и токен из личного кабинета https://www.duckdns.org
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token

# Полное доменное имя, на которое Caddy выпустит сертификат Let's Encrypt
DOMAIN=your-subdomain.duckdns.org

# --- База данных ---
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=ChooseAStrongPasswordHere

# --- Прочее ---
TZ=Europe/Yekaterinburg
